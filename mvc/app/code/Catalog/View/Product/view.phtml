<?php $product = $this->getProduct(); ?>

<?php if ($product->isLoaded()): ?>
    <div class="product-view-container">
        <div class="product-main-section">
            <!-- Left Column -->
            <?php echo $this->getChildHtml('media'); ?>

            <!-- Right Column -->
            <div class="product-info-wrapper">
                <?php echo $this->getChildHtml('info'); ?>
                <?php echo $this->getChildHtml('actions'); ?>
                <?php echo $this->getChildHtml('specs'); ?>
            </div>
        </div>

        <!-- Long Description Section -->
        <?php echo $this->getChildHtml('description'); ?>
    </div>
<?php else: ?>
    <div class="product-not-found">
        <h2>Product does not exist</h2>
        <p>The product you are looking for could not be found.</p>
        <a href="<?php echo $this->base; ?>catalog/product/list">Back to Products</a>
    </div>

<?php endif; ?>